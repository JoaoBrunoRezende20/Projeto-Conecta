rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Libera leitura pública para visitantes, exigindo login apenas para escrever.
    match /produtos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /servicos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categorias/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Libera leitura pública para os visitantes verem as lojas
    match /lojistas/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Libera leitura pública para os prestadores de serviço
    match /prestadorServicos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regra padrão de segurança para as outras coleções
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
